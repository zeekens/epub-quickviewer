<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>com.apple.security.app-sandbox</key>
	<true/>
	<key>com.apple.security.files.user-selected.read-only</key>
	<true/>
	<!-- Required by WKWebView: without it the sandbox kills the WebContent
	     process on load and the window renders blank. The app makes no network
	     requests (book HTML is sanitized, remote images dropped, resources
	     inlined as data: URIs, and non-about: navigations are cancelled).
	     The Quick Look extension does not need this: it hands HTML to
	     Quick Look, which renders it in its own web view. -->
	<key>com.apple.security.network.client</key>
	<true/>
</dict>
</plist>
